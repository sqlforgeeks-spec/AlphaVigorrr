modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/alphavigor: web"

[[workflows.workflow]]
name = "artifacts/alphavigor: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"
previewPath = "/"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=18174 BASE_PATH=/ pnpm --filter @workspace/alphavigor run dev"
waitForPort = 18174

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
